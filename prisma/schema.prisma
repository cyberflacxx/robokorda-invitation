generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum RSVPStatus {
  PENDING
  ACCEPT
  DECLINE
  MAYBE
}

enum GalleryImageType {
  HERO
  GALLERY
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  checkIns CheckIn[]
}

model Guest {
  id          Int        @id @default(autoincrement())
  fullName    String
  gender      Gender?
  email       String?    @unique
  phone       String?    @unique
  inviteToken String     @unique
  rsvpCode    String     @unique
  rsvpStatus  RSVPStatus @default(PENDING)
  isCheckedIn Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rsvp    RSVP?
  checkIn CheckIn?

  @@index([fullName])
  @@index([rsvpStatus])
}

model RSVP {
  id          Int        @id @default(autoincrement())
  guestId     Int        @unique
  status      RSVPStatus
  gender      Gender
  notes       String?    @db.Text
  submittedAt DateTime   @default(now())

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id        Int              @id @default(autoincrement())
  title     String
  imageUrl  String           @unique
  type      GalleryImageType @default(GALLERY)
  isHero    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model CheckIn {
  id          Int      @id @default(autoincrement())
  guestId     Int      @unique
  checkedInAt DateTime @default(now())
  checkedInBy Int

  guest Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  admin AdminUser @relation(fields: [checkedInBy], references: [id])
}

model EventSetting {
  id               Int      @id @default(autoincrement())
  eventName        String
  eventDate        DateTime
  eventTime        String
  venueName        String
  venueAddress     String
  dressCode        String?
  theme            String?
  heroImageUrl     String?
  lightModeLogoUrl String?
  darkModeLogoUrl  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
